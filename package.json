{
  "name": "iobroker.ahoydtu",
  "version": "0.0.1",
  "description": "ioBroker adapter for AhoyDTU Hoymiles inverter gateway (REST API)",
  "author": {
    "name": "Skeletor-ai",
    "email": "skeletor-ai@all-smart.net"
  },
  "contributors": [],
  "homepage": "https://github.com/All-Smart/ioBroker.ahoydtu",
  "license": "MIT",
  "keywords": [
    "ahoydtu",
    "hoymiles",
    "inverter",
    "solar",
    "pv",
    "dtu",
    "photovoltaik",
    "balkonkraftwerk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/All-Smart/ioBroker.ahoydtu.git"
  },
  "engines": {
    "node": ">= 18"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@iobroker/dm-utils": "^3.0.9",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node18": "^18.2.6",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "@types/node": "^18.19.130",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit",
    "translate": "translate-adapter"
  },
  "bugs": {
    "url": "https://github.com/All-Smart/ioBroker.ahoydtu/issues"
  },
  "readmeFilename": "README.md"
}
