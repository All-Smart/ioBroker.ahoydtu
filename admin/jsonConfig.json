{
	"type": "tabs",
	"i18n": true,
	"items": {
		"tab_connection": {
			"type": "tab",
			"label": "Connection",
			"items": {
				"host": {
					"type": "text",
					"label": "Host / IP address",
					"help": "IP address or hostname of AhoyDTU",
					"placeholder": "192.168.0.156",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4,
					"validator": "data.host && data.host.length > 0",
					"validatorErrorText": "Host is required"
				},
				"port": {
					"type": "number",
					"label": "Port",
					"help": "HTTP port of AhoyDTU (usually 80)",
					"placeholder": "80",
					"min": 1,
					"max": 65535,
					"newLine": false,
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"pollInterval": {
					"type": "number",
					"label": "Poll interval (seconds)",
					"help": "How often to fetch data from AhoyDTU (min: 5s, default: 15s)",
					"placeholder": "15",
					"min": 5,
					"max": 3600,
					"newLine": false,
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"password": {
					"type": "password",
					"label": "Password (optional)",
					"help": "Only required if AhoyDTU is password-protected",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				}
			}
		},
		"tab_devices": {
			"type": "tab",
			"label": "Devices",
			"items": {
				"deviceManager": {
					"type": "deviceManager",
					"xs": 12
				}
			}
		}
	}
}
